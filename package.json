{
  "name": "@letar/forms",
  "version": "1.0.0",
  "description": "Declarative form components for React with 40+ field types, powered by TanStack Form and Chakra UI v3",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./offline": {
      "types": "./offline.d.ts",
      "import": "./offline.js"
    },
    "./i18n": {
      "types": "./i18n.d.ts",
      "import": "./i18n.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./index.js",
  "types": "./index.d.ts",
  "files": [
    "**/*.js",
    "**/*.js.map",
    "**/*.d.ts",
    "**/*.d.ts.map",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "react",
    "forms",
    "form-components",
    "tanstack-form",
    "chakra-ui",
    "zod",
    "declarative",
    "typescript",
    "validation",
    "multi-step",
    "offline",
    "i18n"
  ],
  "homepage": "https://forms.letar.best",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamiletar/letar-forms"
  },
  "bugs": {
    "url": "https://github.com/kamiletar/letar-forms/issues"
  },
  "peerDependencies": {
    "@chakra-ui/react": ">=3.0.0",
    "@dnd-kit/core": ">=6.0.0",
    "@dnd-kit/sortable": ">=10.0.0",
    "@dnd-kit/utilities": ">=3.0.0",
    "@tanstack/react-form": ">=1.0.0",
    "framer-motion": ">=10.0.0",
    "react": ">=18.0.0",
    "react-icons": ">=5.0.0",
    "use-mask-input": ">=3.0.0",
    "zod": ">=3.24.0"
  },
  "peerDependenciesMeta": {
    "@dnd-kit/core": {
      "optional": true
    },
    "@dnd-kit/sortable": {
      "optional": true
    },
    "@dnd-kit/utilities": {
      "optional": true
    },
    "@tiptap/react": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    },
    "next-intl": {
      "optional": true
    },
    "use-mask-input": {
      "optional": true
    }
  }
}
